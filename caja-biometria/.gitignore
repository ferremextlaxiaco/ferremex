# Binario compilado (se genera con compilar.bat)
FerremexBiometriaService.exe
*.pdb

# Logs en runtime
biometria.log
biometria.log.old
_test_run.log

# DLLs redistribuibles de DigitalPersona (se copian del Runtime; no versionar binarios grandes)
dpfj.dll
dpfpdd.dll
dpfpdd*.dll

# Instalador del Runtime DigitalPersona (98MB cab — demasiado pesado para git;
# se distribuye por otra vía, igual que caddy.exe en caja-proxy)
runtime-digitalpersona/

# Driver del lector 4500 (HID Global / Authentication Devices, binarios .sys/.dll
# exportados del DriverStore). Se distribuye por USB, no se versiona en git.
# Para regenerarlo desde una maquina que YA tiene el driver correcto:
#   pnputil /export-driver oem16.inf <carpeta>   (oem16 = el de "HID Global"/"Authentication Devices")
driver-4500/
